---
// src/components/Formation.astro

const courses = [
  {
    title: "Análise e Desenvolvimento de Sistemas",
    institution: "UNINTER",
    year: "2023",
  },
  {
    title: "JavaScript Completo ECMS 6+",
    institution: "ORIGAMID",
    year: "2024",
  },
  {
    title: "UI/UX Design Avançado",
    institution: "ORIGAMID",
    year: "2024",
  },
];
---

<section class="formation-section" id="formacao">
  <div class="formation-container">
    <div class="formation-header">
      <h2>Formação</h2>
      <p>Graduação & Cursos</p>
    </div>

    <div class="formation-list">
      {
        courses.map((course) => (
          <div class="formation-card">
            <div class="icon-block">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="grad-icon"
              >
                <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
                <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5" />
              </svg>
            </div>

            <div class="card-info">
              <h3 class="course-title">{course.title}</h3>
              <p class="course-institution">{course.institution}</p>
            </div>

            <div class="card-year">{course.year}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .formation-section {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 4rem 6rem 4rem;
  }

  .formation-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5rem;
  }

  /* Cabeçalho centralizado conforme image_81b6c0.png */
  .formation-header {
    text-align: center;
  }

  .formation-header h2 {
    font-family: var(--font-main);
    font-size: 2.2rem;
    font-weight: 800;
    color: #000000;
    margin-bottom: 0.25rem;
  }

  .formation-header p {
    font-family: var(--font-main);
    font-size: 1.1rem;
    color: #555555;
    font-weight: 500;
  }

  /* Lista de blocos horizontais */
  .formation-list {
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Estilo Padrão para TODOS os cards (Branco com borda e texto pretos) */
  .formation-card {
    background-color: #ffffff;
    border: 3px solid #000000;
    display: flex;
    align-items: center;
    padding: 0.75rem;
    position: relative;
    cursor: pointer;
    box-shadow: 0px 0px 0px #000000;
    /* Atualizado: adicionado suporte suave para transformações e sombras brutais */
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  /* Bloco do Ícone Quadrado Neutro */
  .icon-block {
    background-color: #000000;
    color: #ffffff;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 1.5rem;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  /* Ícone com traços finos e elegantes */
  .grad-icon {
    width: 24px;
    height: 24px;
  }

  /* Textos do Card */
  .card-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .course-title {
    font-family: var(--font-main);
    font-size: 1.4rem;
    font-weight: 800;
    color: #000000;
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .course-institution {
    font-family: var(--font-main);
    font-size: 0.9rem;
    font-weight: 700;
    color: #555555;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.2s ease;
  }

  /* Ano na Extremidade Direita */
  .card-year {
    font-family: var(--font-main);
    font-size: 1.5rem;
    font-weight: 900;
    color: #000000;
    margin-right: 1rem;
    transition: color 0.2s ease;
  }

  /* ==========================================================================
     HOVER DINÂMICO: Transforma qualquer card no padrão da image_81b6c0.png
     Efeito de elevação adicionado!
     ========================================================================== */
  .formation-card:hover {
    background-color: #000000;
    /* Atualizado: Desloca o bloco para cima e projeta a sombra preta clássica */
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0px #000000;
  }

  .formation-card:hover .icon-block {
    background-color: var(--color-primary); /* Caixinha fica laranja #FCA100 */
    color: #000000; /* Ícone fino fica preto em cima do laranja */
  }

  .formation-card:hover .course-title {
    color: #ffffff;
  }

  .formation-card:hover .course-institution {
    color: #bbbbbb;
  }

  .formation-card:hover .card-year {
    color: var(--color-primary); /* O ano acende no seu laranja conceitual */
  }

  /* Responsividade */
  @media (max-width: 640px) {
    .formation-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem 1rem;
      gap: 1rem;
    }

    /* Reseta o deslocamento no mobile se preferir evitar problemas de toque em telas pequenas */
    .formation-card:hover {
      transform: none;
      box-shadow: none;
    }

    .icon-block {
      margin-right: 0;
    }

    .card-year {
      margin-right: 0;
      font-size: 1.3rem;
    }

    .course-title {
      font-size: 1.2rem;
    }
  }
</style>
