  }

  .status-box.error {
    background-color: #ff8e8e;
  }

  @media (max-width: 768px) {
    .side-arrow {
      display: none;
    }

    .contact-section {
      padding: 4rem 2rem 6rem 2rem;
    }

    .contact-content-wrapper {
      gap: 0;
    }
  }
</style>
